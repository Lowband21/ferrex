<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Leanback TV devices; touch is optional for remotes/controllers. -->
    <uses-feature android:name="android.software.leanback" android:required="true" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application android:banner="@drawable/tv_banner">

        <!-- TvMainActivity is the Leanback launcher for this flavor. -->
        <activity android:name=".MainActivity" tools:node="remove" />

        <activity
            android:name=".tv.TvMainActivity"
            android:exported="true"
            android:theme="@style/Theme.Ferrex.Splash"
            android:colorMode="hdr"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|colorMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
